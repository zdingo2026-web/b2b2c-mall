# ============================================================
# B2B2C Mall - Environment Variables
# Copy this file to .env and fill in your values before running
# docker-compose up.
# ============================================================

# JWT secret (at least 32 characters, must be the same across all services)
MALL_JWT_SECRET=changeMeToAStrongRandomSecretKeyAtLeast32Chars!!

# MySQL
MYSQL_URL=jdbc:mysql://localhost:3306/mall_b2b2c?useUnicode=true&characterEncoding=UTF-8&useSSL=false&serverTimezone=Asia/Shanghai
MYSQL_USERNAME=root
MYSQL_PASSWORD=root123

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=mall
RABBITMQ_PASSWORD=mall123
RABBITMQ_VHOST=/

# MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=mall-dev
MINIO_URL_PREFIX=http://localhost:9000/mall-dev/
